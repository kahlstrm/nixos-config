{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git branch *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      "docker ps *": "allow",
      "docker images *": "allow",
      "docker inspect *": "allow",
      "which *": "allow",
      "gh pr view *": "allow",
      "gh issue view *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "mkdir *": "allow",
      "wc *": "allow"
    }
  }
}
